# Environment variables required for the Updater API on Vercel
# You MUST add these to your Vercel Project Settings -> Environment Variables

# The passcode to access the Updater portal (e.g., 7830)
UPDATER_PASSCODE=7830

# A GitHub Personal Access Token (classic) with `repo` scope to commit updates to data/updates.json
GITHUB_TOKEN=your_github_token_here
